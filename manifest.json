{
  "manifest_version": 3,
  "name": "GitHub PR Review Assistant",
  "version": "1.0.0",
  "description": "Tự động hiển thị Side Panel hỗ trợ review Pull Request khi vào tab Files changed.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "GitHub PR Assistant",
    "default_icon": "icons/github.png"
  },
  "icons": {
    "16": "icons/github.png",
    "32": "icons/github.png",
    "48": "icons/github.png",
    "128": "icons/github.png"
  }
}
